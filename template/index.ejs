              <div class="tw-card-platform"><% if (t.platform === 'threads') { %><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.96-.065-1.187.408-2.281 1.332-3.078.856-.74 2.062-1.155 3.59-1.236 1.107-.058 2.133.037 3.08.272-.107-1.24-.683-1.876-1.373-2.225-.825-.418-1.96-.464-3.074-.282l-.313-2.082c1.46-.238 2.986-.196 4.226.43 1.076.544 1.834 1.456 2.253 2.74.395-.158.822-.28 1.284-.356l.387 2.06c-.36.07-.7.168-1.017.29.088.453.14.928.154 1.42.009.394-.008.794-.059 1.2.744.588 1.328 1.348 1.723 2.252.786 1.798.818 4.577-1.26 6.61C18.04 23.1 15.627 23.98 12.186 24zm.287-9.737c-1.32.069-2.267.453-2.655.94-.265.332-.312.734-.284 1.244.038.696.384 1.164.97 1.544.66.428 1.42.597 2.18.559 1.07-.058 1.876-.436 2.442-1.14.498-.618.852-1.504 1.014-2.637-.88-.32-1.92-.536-3.114-.536-.188 0-.371.007-.553.026z"/></svg><% } else { %><svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg><% } %></div>
