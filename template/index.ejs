        <div class="mini-quote-content">
          <p class="mini-quote-text" style="color:rgba(0,0,0,0.6);">「<%= q.quote %>」</p>
          <div class="mini-quote-author" style="color:rgba(0,0,0,0.35);"><%= q.author %> · <%= q.role %></div>
