  <!-- ======================== -->
  <!-- SCRIPTS                  -->
  <!-- ======================== -->
  <script>
    // Scroll Animation
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // FAQ Accordion
    // Typewriter effect (loops every 15s)
    (function() {
      const text = '人生升級系統';
      const el = document.getElementById('typewriter-text');
      if (!el) return;
      function typeOut() {
        let i = 0;
        el.textContent = '';
        const timer = setInterval(function() {
          el.textContent = text.substring(0, i + 1);
          i++;
          if (i >= text.length) {
            clearInterval(timer);
            setTimeout(eraseOut, 12000);
          }
        }, 120);
      }
      function eraseOut() {
        let i = text.length;
        const timer = setInterval(function() {
          i--;
          el.textContent = text.substring(0, i);
          if (i <= 0) {
            clearInterval(timer);
            setTimeout(typeOut, 500);
          }
        }, 60);
      }
      const observer = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) {
          typeOut();
          observer.disconnect();
        }
      }, { threshold: 0.5 });
      observer.observe(el.closest('.mid-cta'));
    })();

    // Hero tab switching
    function switchHeroTab(idx) {
      document.querySelectorAll('.hero-tab').forEach((t, i) => t.classList.toggle('active', i === idx));
      document.querySelectorAll('.hero-screen').forEach((s, i) => s.classList.toggle('active', i === idx));
    }

    // Hero scroll tilt
    (function() {
      const mockup = document.getElementById('hero-mockup');
      if (!mockup) return;
      window.addEventListener('scroll', function() {
        const scrollY = window.scrollY;
        const progress = Math.min(scrollY / 500, 1);
        const rotate = 12 * (1 - progress);
        const scale = 0.95 + 0.05 * progress;
        const opacity = 0.9 + 0.1 * progress;
        mockup.style.transform = `rotateX(${rotate}deg) scale(${scale})`;
        mockup.style.opacity = opacity;
      }, { passive: true });
    })();

    // Counter animation
    (function() {
      const counters = document.querySelectorAll('[data-count]');
      if (!counters.length) return;
      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            const el = entry.target;
            const target = parseInt(el.dataset.count);
            const duration = 1500;
            const start = Date.now();
            function tick() {
              const progress = Math.min((Date.now() - start) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              el.textContent = Math.floor(eased * target).toLocaleString();
              if (progress < 1) requestAnimationFrame(tick);
            }
            tick();
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.5 });
      counters.forEach(function(el) { observer.observe(el); });
    })();

    function setLearningMode(n) {
      document.querySelectorAll('.learning-mode').forEach(el => el.classList.remove('active'));
      document.querySelector(`.learning-mode[data-mode="${n}"]`).classList.add('active');
      // Stop all playing videos
      document.querySelectorAll('.learning-preview-placeholder iframe, .learning-preview-img iframe').forEach(function(iframe) {
        iframe.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
        var src = iframe.src;
        iframe.src = src;
      });
      document.querySelectorAll('.learning-preview-placeholder, .learning-preview-img').forEach(el => el.classList.remove('active'));
      const target = document.querySelector(`[data-preview="${n}"]`);
      if (target) target.classList.add('active');
    }

    function showMoreTestimonials() {
      document.getElementById('tw-wall-inner').classList.add('expanded');
      document.getElementById('tw-wall-fade').classList.add('hidden');
      document.getElementById('tw-wall-more').classList.add('hidden');
    }

    function toggleFaq(btn) {
      const item = btn.closest('.faq-item');
      const wasOpen = item.classList.contains('open');
      // Close all
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      // Toggle clicked
      if (!wasOpen) item.classList.add('open');
    }

    // Meetup dropdown switching
    function switchMeetup(index) {
      document.querySelectorAll('.meetup-panel').forEach(p => p.classList.remove('active'));
      document.querySelector(`.meetup-panel[data-meetup="${index}"]`).classList.add('active');
    }

    // Show more photos
    function showMorePhotos(btn) {
      const panel = btn.closest('.meetup-panel');
      panel.querySelectorAll('.meetup-thumb.hidden').forEach(el => el.classList.remove('hidden'));
      btn.style.display = 'none';
    }

    // Lightbox — works with active meetup panel
    let currentLightbox = 0;
    let currentImages = [];

    function getActiveImages() {
      const panel = document.querySelector('.meetup-panel.active');
      return Array.from(panel.querySelectorAll('.meetup-thumb')).map(thumb => {
        const img = thumb.querySelector('img');
        return img ? img.src : '';
      });
    }

    function openLightbox(index) {
      currentImages = getActiveImages();
      currentLightbox = index;
      const overlay = document.getElementById('lightbox');
      const img = document.getElementById('lightbox-img');
      const counter = document.getElementById('lightbox-counter');
      img.src = currentImages[index] || '';
      counter.textContent = `${index + 1} / ${currentImages.length}`;
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      document.getElementById('lightbox').classList.remove('active');
      document.body.style.overflow = '';
    }

    function navLightbox(dir) {
      currentLightbox = (currentLightbox + dir + currentImages.length) % currentImages.length;
      const img = document.getElementById('lightbox-img');
      const counter = document.getElementById('lightbox-counter');
      img.src = currentImages[currentLightbox] || '';
      counter.textContent = `${currentLightbox + 1} / ${currentImages.length}`;
    }

    // Close lightbox on overlay click
    document.getElementById('lightbox').addEventListener('click', function(e) {
      if (e.target === this) closeLightbox();
    });

    // Keyboard nav for lightbox
    document.addEventListener('keydown', function(e) {
      const overlay = document.getElementById('lightbox');
      if (!overlay.classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navLightbox(-1);
      if (e.key === 'ArrowRight') navLightbox(1);
    });
  </script>
</body>
</html>
